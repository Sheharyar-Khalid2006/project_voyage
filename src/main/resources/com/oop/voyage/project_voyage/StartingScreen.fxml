<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.oop.voyage.project_voyage.StartingScreen"
        fx:id="rootPane"
        stylesheets="@Styles.css"
        styleClass="start-root">

    <Pane styleClass="bg-gradient" />

    <VBox fx:id="contentBox" styleClass="start-content" alignment="CENTER">

        <VBox styleClass="logo-section" alignment="CENTER">
            <Label fx:id="logoIconLabel" text="🚗" styleClass="logo-icon" />
            <Label fx:id="appTitleLabel" text="Voyage" styleClass="app-title" />
            <Label text="Let us take care of your travel hassle" styleClass="app-tagline" />
        </VBox>

        <HBox fx:id="cardsRow" styleClass="cards-row" alignment="CENTER">
            <!-- The CSS classes/IDs for Driver are named but not implemented yet in CSS-->
            <VBox
                    fx:id="driverCard"
                    styleClass="role-card, driver-card"
                    alignment="CENTER"
                    onMouseClicked="#onDriverCardClicked"
                    onMouseEntered="#onDriverHover"
                    onMouseExited="#onDriverUnhover">
                <padding><Insets top="40" right="30" bottom="30" left="30"/></padding>
                <Label text="🚘" styleClass="card-emoji" />
                <Label text="Driver" styleClass="card-role-title" />
                <Label text="Offer rides &amp; earn" wrapText="true" textAlignment="CENTER" styleClass="card-role-sub" />
                <Region VBox.vgrow="ALWAYS" minHeight="15" />
                <Button text="Select →" styleClass="card-btn, driver-btn" mouseTransparent="true" />
            </VBox>

            <Region minWidth="60" HBox.hgrow="NEVER" />

            <!-- The CSS classes/IDs for passenger are named but not implemented yet in CSS-->
            <VBox
                    fx:id="passengerCard"
                    styleClass="role-card, passenger-card"
                    alignment="CENTER"
                    onMouseClicked="#onPassengerCardClicked"
                    onMouseEntered="#onPassengerHover"
                    onMouseExited="#onPassengerUnhover">
                <padding><Insets top="40" right="30" bottom="30" left="30"/></padding>
                <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
                        <Image url="@passenger.png" />
                </ImageView>
                <Label text="Passenger" styleClass="card-role-title" />
                <Label text="Book a ride &amp; travel" wrapText="true" styleClass="card-role-sub" textAlignment="CENTER" />
                <Region VBox.vgrow="ALWAYS" minHeight="15" />
                <Button text="Select →" styleClass="card-btn, passenger-btn" mouseTransparent="true" />
            </VBox>
        </HBox>

        <Separator styleClass="section-divider" maxWidth="360" />

        <Label text="© 2026 Voyage  •  Safe and Hassle Free Travels Await"
               styleClass="footer-label" />

    </VBox>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Separator?>

<StackPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.oop.voyage.project_voyage.LoginScreen"
        fx:id="rootPane"
        styleClass="login-root">

    <VBox fx:id="formCard" styleClass="form-card" alignment="TOP_CENTER" spacing="16">
        <padding><Insets top="40" right="56" bottom="40" left="56"/></padding>

        <HBox styleClass="role-badge-row" alignment="CENTER" spacing="10">
            <Label fx:id="roleIconLabel" text="👤" styleClass="form-role-icon" />
            <Label fx:id="roleTitleLabel" text="Login" styleClass="form-role-title" />
        </HBox>
        <Label fx:id="roleSubtitleLabel"
               text="Enter your details to continue"
               styleClass="form-subtitle" />

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="CNIC" styleClass="field-label" />
                <TextField fx:id="cnicField"
                           promptText="e.g. 35202-1234567-1"
                           styleClass="form-field"
                           maxWidth="Infinity" />
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Phone Number" styleClass="field-label" />
                <TextField fx:id="phoneField"
                           promptText="e.g. 0300-1234567"
                           styleClass="form-field"
                           maxWidth="Infinity" />
            </VBox>
        </HBox>

        <Label text="Gmail (Optional)" styleClass="field-label" />
        <TextField fx:id="gmailField"
                   promptText="yourname@gmail.com"
                   styleClass="form-field" />

        <!-- Driver-only section — toggled by initRole() -->
        <VBox fx:id="driverSection" styleClass="driver-section" spacing="0"
              visible="false" managed="false">

            <Separator styleClass="driver-divider">
                <VBox.margin><Insets top="10" bottom="18"/></VBox.margin>
            </Separator>

            <Label text="🚘 Vehicle Information" styleClass="section-header" />

            <Label text="Car Type" styleClass="field-label" />
            <ComboBox fx:id="carTypeCombo"
                      promptText="Select your car type"
                      styleClass="form-combo"
                      maxWidth="Infinity" />

            <Label text="Vehicle Number Plate" styleClass="field-label">
                <VBox.margin><Insets top="12"/></VBox.margin>
            </Label>
            <TextField fx:id="plateField"
                       promptText="e.g. ABC-123"
                       styleClass="form-field plate-field" />
        </VBox>

        <Button text="Continue →" styleClass="continue-btn"
                maxWidth="Infinity" onAction="#onContinueClicked">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Button>
    </VBox>
</StackPane>
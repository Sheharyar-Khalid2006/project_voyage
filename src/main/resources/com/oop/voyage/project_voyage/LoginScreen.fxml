<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" styleClass="login-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.voyage.project_voyage.LoginScreen">

    <BorderPane maxHeight="Infinity" maxWidth="Infinity">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-min-height: 60px; -fx-pref-height: 60px;" styleClass="top-bar">
                <padding><Insets bottom="15" left="30" right="30" top="15" /></padding>
                <Button focusTraversable="false" mnemonicParsing="false" onAction="#onBackClicked" prefHeight="70.0" prefWidth="100.0" styleClass="back-btn" text="&lt;- Back" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="topBadgeLabel" styleClass="top-logo" text="Voyage" />
            </HBox>
        </top>

        <center>
            <VBox alignment="TOP_CENTER">
                <padding><Insets bottom="20" top="20" /></padding>

                <VBox fx:id="formCard" alignment="TOP_CENTER" spacing="16" styleClass="form-card">
                    <padding><Insets bottom="15" left="50" right="50" top="15" /></padding>

                    <HBox alignment="CENTER" spacing="10" styleClass="role-badge-row">
                        <Label fx:id="roleIconLabel" styleClass="form-role-icon" text="👤" />
                        <Label fx:id="roleTitleLabel" styleClass="form-role-title" text="Login" />
                    </HBox>
                    <Label fx:id="roleSubtitleLabel" styleClass="form-subtitle" text="Enter your details to continue" />

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="CNIC" />
                            <TextField fx:id="cnicField" maxWidth="Infinity" promptText="e.g. 35202-1234567-1" styleClass="form-field" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Phone Number" />
                            <TextField fx:id="phoneField" maxWidth="Infinity" promptText="e.g. 0300-1234567" styleClass="form-field" />
                        </VBox>
                    </HBox>

                    <Label styleClass="field-label" text="Gmail (Optional)">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Label>
                    <TextField fx:id="gmailField" promptText="yourname@gmail.com" styleClass="form-field" />

                    <!-- Driver-only section — toggled by initRole() -->
                    <VBox fx:id="driverSection" managed="false" styleClass="driver-section" visible="false">

                        <Separator styleClass="driver-divider">
                            <VBox.margin><Insets bottom="10" top="5" /></VBox.margin>
                        </Separator>

                        <Label styleClass="section-header" text="🚘 Vehicle Information" />

                        <Label styleClass="field-label" text="Car Type" />
                        <ComboBox fx:id="carTypeCombo" maxWidth="Infinity" promptText="Select your car type" styleClass="form-combo" />

                        <Label styleClass="field-label" text="Vehicle Number Plate">
                            <VBox.margin><Insets top="10" /></VBox.margin>
                        </Label>
                        <TextField fx:id="plateField" promptText="e.g. ABC-123" styleClass="form-field plate-field" />
                    </VBox>

                    <Button maxWidth="Infinity" onAction="#onContinueClicked" styleClass="continue-btn" text="Continue -&gt;">
                        <VBox.margin><Insets bottom="5" top="5" /></VBox.margin>
                    </Button>
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>

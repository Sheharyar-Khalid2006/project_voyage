<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="login-root"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.voyage.project_voyage.DriverDashboard">

    <BorderPane maxWidth="Infinity" maxHeight="Infinity">
        <top>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
                <Label text="🚘 Driver Dashboard" styleClass="top-logo"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="plateLabel" styleClass="field-label" text="---"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" styleClass="login-root">
                <VBox spacing="18" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Vehicle Type" styleClass="field-label"/>
                            <Label fx:id="carTypLabel" styleClass="form-role-title" text="---"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Seats Available" styleClass="field-label"/>
                            <Label fx:id="seatsLabel" styleClass="form-role-title" text="--"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="ETA to Destination" styleClass="field-label"/>
                            <Label fx:id="etaLabel" styleClass="form-role-title" text="---"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Est. Fare" styleClass="field-label"/>
                            <Label fx:id="fareLabel" styleClass="form-role-title" text="PKR --"/>
                        </VBox>
                    </HBox>

                    <VBox styleClass="form-card" spacing="12">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label text="🗺 Set Drop-off Destination" styleClass="section-header"/>
                        <HBox spacing="16">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Destination Latitude" styleClass="field-label"/>
                                <TextField fx:id="destLatField" promptText="e.g. 33.1620"
                                           styleClass="form-field"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Destination Longitude" styleClass="field-label"/>
                                <TextField fx:id="destLngField" promptText="e.g. 73.7650"
                                           styleClass="form-field"/>
                            </VBox>
                        </HBox>
                        <Button text="Confirm Destination" onAction="#onSetDestination"
                                styleClass="continue-btn" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="form-card" spacing="10">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label text="👥 Onboard Passengers" styleClass="section-header"/>
                        <ListView fx:id="paxList" prefHeight="120" styleClass="form-field"/>
                        <!-- onAddTestPassenger method still needs to be defined in .java file -->
                        <Button text="+ Simulate Passenger Boarding"
                                onAction="#onAddTestPassenger"
                                styleClass="card-btn" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="form-card" spacing="10">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label text="🔔 Notifications" styleClass="section-header"/>
                        <Label fx:id="notifLabel" styleClass="form-subtitle" text="No alerts yet."
                               wrapText="true"/>
                        <HBox spacing="12">

                            <!-- onWakePassengers method still needs to be defined in .java file -->
                            <Button text="Wake All Passengers" onAction="#onWakePassengers"
                                    styleClass="card-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <!-- on method still needs to be defined in .java file -->
                            <Button text="End Ride" onAction="#onEndRide"
                                    styleClass="back-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>
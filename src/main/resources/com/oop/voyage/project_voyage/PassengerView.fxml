<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="login-root"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.voyage.project_voyage.PassengerView">

    <BorderPane maxWidth="Infinity" maxHeight="Infinity">

        <top>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
                <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
                    <Image url="@passenger.png"/>
                </ImageView>
                <Label text="Passenger View" styleClass="top-logo"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" styleClass="login-root">
                <VBox spacing="18" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>

                    <VBox styleClass="form-card" alignment="CENTER">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label fx:id="statusLabel" styleClass="form-role-title"
                               text="Setting up..." wrapText="true"/>
                    </VBox>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Estimated Fare" styleClass="field-label"/>
                            <Label fx:id="fareLabel" styleClass="section-header" text="PKR --"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Distance / ETA" styleClass="field-label"/>
                            <Label fx:id="etaLabel" styleClass="section-header" text="---"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Seats in Vehicle" styleClass="field-label"/>
                            <Label fx:id="seatsLabel" styleClass="section-header" text="--"/>
                        </VBox>
                    </HBox>

                    <VBox styleClass="form-card" spacing="12">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label text="📍 Where do you want to go?" styleClass="section-header"/>
                        <HBox spacing="16">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Destination Latitude" styleClass="field-label"/>
                                <TextField fx:id="destLatField" promptText="e.g. 33.1620"
                                           styleClass="form-field"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Destination Longitude" styleClass="field-label"/>
                                <TextField fx:id="destLngField" promptText="e.g. 73.7650"
                                           styleClass="form-field"/>
                            </VBox>
                        </HBox>
                        <!-- onConfirmDestination method still needs to be defined in .java file -->
                        <Button text="Confirm Destination →" onAction="#onConfirmDestination"
                                styleClass="continue-btn" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="form-card" spacing="12">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label text="⏰ Alarm Settings" styleClass="section-header"/>
                        <Label fx:id="alarmStatusLabel" styleClass="form-subtitle"
                               text="No alarm set." wrapText="true"/>

                        <Label text="Set Timed Alarm (24h format)" styleClass="field-label"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TextField fx:id="alarmHrField" promptText="Hour e.g. 14"
                                       prefWidth="140" styleClass="form-field"/>
                            <Label text=":" styleClass="field-label"/>
                            <TextField fx:id="alarmMinField" promptText="Min e.g. 30"
                                       prefWidth="140" styleClass="form-field"/>
                            <!-- onSetTimedAlarm method still needs to be defined in .java file -->
                            <Button text="Set Alarm" onAction="#onSetTimedAlarm"
                                    styleClass="card-btn"/>
                        </HBox>

                        <Button text="Toggle Proximity Alarm ON/OFF"
                                onAction="#onToggleProximityAlarm"
                                styleClass="continue-btn" maxWidth="Infinity"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>
</StackPane>
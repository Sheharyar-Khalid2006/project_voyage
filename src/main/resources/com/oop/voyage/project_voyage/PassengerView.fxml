<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="login-root"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.voyage.project_voyage.PassengerView">

    <BorderPane maxWidth="Infinity" maxHeight="Infinity">

        <top>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
                <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
                    <Image url="@passenger.png"/>
                </ImageView>
                <Label text="Passenger View" styleClass="top-logo"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" styleClass="login-root">
                <VBox spacing="18" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>

                    <VBox styleClass="form-card" alignment="CENTER">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                        <Label fx:id="statusLabel" styleClass="form-role-title"
                               text="Setting up..." wrapText="true"/>
                    </VBox>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Estimated Fare" styleClass="field-label"/>
                            <Label fx:id="fareLabel" styleClass="section-header" text="PKR --"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Distance / ETA" styleClass="field-label"/>
                            <Label fx:id="etaLabel" styleClass="section-header" text="---"/>
                        </VBox>
                        <VBox styleClass="form-card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <Label text="Seats in Vehicle" styleClass="field-label"/>
                            <Label fx:id="seatsLabel" styleClass="section-header" text="--"/>
                        </VBox>
                    </HBox>

                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>
</StackPane>